{
  "name": "draggable-table-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @draggable-table-app/playground dev",
    "dev:docs": "pnpm --filter @draggable-table-app/docs dev",
    "build": "pnpm --filter \"./packages/*\" run build",
    "build:apps": "pnpm --filter \"./apps/*\" run build",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit -p . && pnpm -r --parallel run typecheck",
    "test": "pnpm -r --parallel run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
